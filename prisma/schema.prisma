generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  headerImage   String?
  password      String?
  bio           String?  @db.Text
  aboutMe       String?  @db.Text
  links         String?  @db.Text

  accounts             Account[]
  sessions             Session[]
  posts                Post[]
  comments             PostComment[]
  sentPullRequests     ArticlePullRequest[] @relation("PullRequestSender")
  receivedPullRequests ArticlePullRequest[] @relation("PullRequestRecipient")
  sentMessages         DirectMessage[]      @relation("DirectMessageSender")
  receivedMessages     DirectMessage[]      @relation("DirectMessageRecipient")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  excerpt     String?
  headerImage String?
  tags        String[]
  published   Boolean  @default(false)
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    String
  comments    PostComment[]
}

model Product {
  id    String @id @default(cuid())
  name  String
  desc  String
  color String @default("#e8d5d0")
}

enum DirectMessageSetting {
  OPEN
  PR_ONLY
  CLOSED
}

enum PullRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DirectMessageContext {
  GENERAL
  PULL_REQUEST
}

model PostComment {
  id        String   @id @default(cuid())
  content   String   @db.VarChar(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId   String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  @@index([postId, authorId, createdAt])
}

model ArticlePullRequest {
  id        String   @id @default(cuid())
  title     String
  excerpt   String?  @db.Text
  content   String   @db.Text
  tags      String[]
  status    PullRequestStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposer   User   @relation("PullRequestSender", fields: [proposerId], references: [id], onDelete: Cascade)
  proposerId String
  recipient  User   @relation("PullRequestRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String

  messages DirectMessage[]

  @@index([recipientId, createdAt])
  @@index([proposerId, createdAt])
}

model DirectMessage {
  id        String   @id @default(cuid())
  content   String   @db.VarChar(10000)
  context   DirectMessageContext @default(GENERAL)
  createdAt DateTime @default(now())

  sender    User   @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId  String
  recipient User   @relation("DirectMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String

  pullRequest   ArticlePullRequest? @relation(fields: [pullRequestId], references: [id], onDelete: SetNull)
  pullRequestId String?

  @@index([recipientId, createdAt])
  @@index([senderId, createdAt])
  @@index([pullRequestId])
}
